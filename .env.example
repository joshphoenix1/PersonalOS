# News aggregator config
# Copy to .env and adjust for local / EC2

# SQLite path (relative to repo root or absolute)
DB_PATH=./data/news.db

# FastAPI bind
HOST=127.0.0.1
PORT=8000

# Scheduler cadence (minutes)
NEWS_INTERVAL_MIN=15
WEATHER_INTERVAL_MIN=60

# Major-news stickiness window (hours)
MAJOR_STICKY_HOURS=12

# Retention — prune articles older than N hours
ARTICLE_RETENTION_HOURS=72

# Log level
LOG_LEVEL=INFO
